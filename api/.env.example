# Set to "true" only in local development — shows real exception messages in
# API error responses. Leave unset/false in production (errors are still
# logged server-side via error_log either way).
APP_DEBUG=false

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Email
CONTACT_EMAIL=admin@example.com
NOREPLY_EMAIL=no-reply@example.com

# Param POS (ödeme sistemi)
PARAM_RECONCILE_SECRET=your-secret-key

# Opsiyonel: prod DB bilgileri (db.php içindeki hard-coded değerleri override eder)
# DB_HOST=localhost
# DB_NAME=lumanoris
# DB_USER=root
# DB_PASS=
